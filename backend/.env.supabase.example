# Supabase Configuration
DATABASE_URL=jdbc:postgresql://db.YOUR_PROJECT_REF.supabase.co:5432/postgres
DATABASE_USER=postgres
DATABASE_PASSWORD=your_supabase_password_here
JWT_SECRET=your_jwt_secret_here

# Supabase Project Details
# Get these from: https://app.supabase.com/project/YOUR_PROJECT/settings/database
# Connection string format:
# postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Example:
# DATABASE_URL=jdbc:postgresql://db.abcdefghijklmnop.supabase.co:5432/postgres
# DATABASE_USER=postgres
# DATABASE_PASSWORD=your_super_secret_password
