# ML Service environment variables

# Core service
PINECONE_API_KEY=
PINECONE_INDEX=dental-kb
PINECONE_REGION=us-east-1
GEMINI_API_KEY=
GROQ_API_KEY=

# 9router (OpenAI-compatible)
NINEROUTER_API_KEY=
NINEROUTER_BASE_URL=https://api.9router.com/v1
NINEROUTER_MODEL=gemini-2.0-flash

# Model selection
MODEL_BACKEND=svm
MODELS_DIR=./models

# Optional: mock Gemini for offline testing (set to 1 to enable)
MOCK_GEMINI=0

